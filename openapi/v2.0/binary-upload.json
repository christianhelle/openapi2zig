{
  "swagger": "2.0",
  "info": {
    "title": "Binary Upload Sample",
    "version": "1.0.0"
  },
  "host": "example.com",
  "basePath": "/v1",
  "schemes": ["https"],
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "paths": {
    "/upload": {
      "post": {
        "operationId": "uploadBinary",
        "summary": "Upload a binary file",
        "consumes": ["application/octet-stream"],
        "parameters": [
          {
            "name": "file",
            "in": "body",
            "required": true,
            "schema": {
              "type": "string",
              "format": "binary"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Upload succeeded"
          }
        }
      }
    },
    "/echo": {
      "post": {
        "operationId": "echoJson",
        "summary": "Echo a JSON body using spec-level consumes",
        "parameters": [
          {
            "name": "payload",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok"
          }
        }
      }
    }
  }
}
